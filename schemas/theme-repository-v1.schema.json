{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-skin.dev/schemas/theme-repository-v1.schema.json",
  "title": "Codex Skin theme repository v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "updatedAt", "themes"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "updatedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "themes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "manifest"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "manifest": { "type": "string", "pattern": "^themes/[a-z0-9][a-z0-9-]*\\.json$" }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" }
  }
}
