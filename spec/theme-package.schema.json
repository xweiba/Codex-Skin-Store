{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/lixiaobaivv/Codex-Dream-Skin-Store/main/spec/theme-package.schema.json",
  "title": "Codex Dream Skin theme package manifest",
  "description": "Schema for the theme.json manifest at the root of a signed .dreamskin package.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageVersion",
    "id",
    "name",
    "version",
    "description",
    "author",
    "engineVersion",
    "platforms",
    "image",
    "colors",
    "assets",
    "signature"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://raw.githubusercontent.com/lixiaobaivv/Codex-Dream-Skin-Store/main/spec/theme-package.schema.json"
    },
    "schemaVersion": {
      "description": "Runtime theme schema understood by the current Codex Dream Skin injector.",
      "type": "integer",
      "const": 1
    },
    "packageVersion": {
      "description": "Version of this package contract.",
      "type": "integer",
      "const": 1
    },
    "id": {
      "description": "Immutable, store-wide theme identifier. A publisher prefix is recommended.",
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "name": {
      "$ref": "#/$defs/nameText"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "description": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "maxLength": 500
        }
      ]
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nameText"
        },
        "homepage": {
          "type": "string",
          "maxLength": 2048,
          "pattern": "^https://[^\\s]+$"
        }
      }
    },
    "engineVersion": {
      "description": "Compatible half-open SemVer range: min <= engine < maxExclusive.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "maxExclusive"
      ],
      "properties": {
        "min": {
          "$ref": "#/$defs/semver"
        },
        "maxExclusive": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": [
          "macos",
          "windows"
        ]
      }
    },
    "brandSubtitle": {
      "$ref": "#/$defs/shortText"
    },
    "tagline": {
      "$ref": "#/$defs/longText"
    },
    "projectPrefix": {
      "$ref": "#/$defs/shortText"
    },
    "projectLabel": {
      "$ref": "#/$defs/shortText"
    },
    "statusText": {
      "$ref": "#/$defs/shortText"
    },
    "quote": {
      "$ref": "#/$defs/shortText"
    },
    "image": {
      "description": "Runtime background filename. It must equal assets.background.path.",
      "enum": [
        "background.png",
        "background.jpg",
        "background.jpeg",
        "background.webp"
      ]
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "background",
        "panel",
        "panelAlt",
        "accent",
        "accentAlt",
        "secondary",
        "highlight",
        "text",
        "muted",
        "line"
      ],
      "properties": {
        "background": {
          "$ref": "#/$defs/color"
        },
        "panel": {
          "$ref": "#/$defs/color"
        },
        "panelAlt": {
          "$ref": "#/$defs/color"
        },
        "accent": {
          "$ref": "#/$defs/color"
        },
        "accentAlt": {
          "$ref": "#/$defs/color"
        },
        "secondary": {
          "$ref": "#/$defs/color"
        },
        "highlight": {
          "$ref": "#/$defs/color"
        },
        "text": {
          "$ref": "#/$defs/color"
        },
        "muted": {
          "$ref": "#/$defs/color"
        },
        "line": {
          "$ref": "#/$defs/color"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "background",
        "preview"
      ],
      "properties": {
        "background": {
          "$ref": "#/$defs/backgroundAsset"
        },
        "preview": {
          "$ref": "#/$defs/previewAsset"
        }
      }
    },
    "signature": {
      "description": "Store or publisher signature over the RFC 8785 canonical manifest with signature.value omitted.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "canonicalization",
        "keyId",
        "signedAt",
        "value"
      ],
      "properties": {
        "algorithm": {
          "const": "Ed25519"
        },
        "canonicalization": {
          "const": "RFC8785"
        },
        "keyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "signedAt": {
          "type": "string",
          "format": "date-time"
        },
        "value": {
          "description": "Unpadded base64url encoding of a 64-byte Ed25519 signature.",
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{86}$"
        }
      }
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*$"
    },
    "nameText": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "maxLength": 80
        }
      ]
    },
    "shortText": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "maxLength": 80
        }
      ]
    },
    "longText": {
      "allOf": [
        {
          "$ref": "#/$defs/safeText"
        },
        {
          "type": "string",
          "maxLength": 160
        }
      ]
    },
    "semver": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "color": {
      "description": "A six-digit hex color or a bounded rgba() value; arbitrary CSS is not accepted.",
      "type": "string",
      "maxLength": 32,
      "oneOf": [
        {
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        {
          "pattern": "^rgba\\((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]),[ ]*(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]),[ ]*(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]),[ ]*(0|1|0?\\.[0-9]{1,3}|1\\.0{1,3})\\)$"
        }
      ]
    },
    "assetCore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "mediaType",
        "bytes",
        "width",
        "height",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "mediaType": {
          "enum": [
            "image/png",
            "image/jpeg",
            "image/webp"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16777216
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8192
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8192
        },
        "sha256": {
          "description": "Lowercase hexadecimal SHA-256 of the exact file bytes.",
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "backgroundAsset": {
      "allOf": [
        {
          "$ref": "#/$defs/assetCore"
        },
        {
          "type": "object",
          "properties": {
            "bytes": {
              "type": "integer",
              "maximum": 16777216
            },
            "width": {
              "type": "integer",
              "maximum": 8192
            },
            "height": {
              "type": "integer",
              "maximum": 8192
            }
          }
        },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "path": {
                  "const": "background.png"
                },
                "mediaType": {
                  "const": "image/png"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "path": {
                  "enum": [
                    "background.jpg",
                    "background.jpeg"
                  ]
                },
                "mediaType": {
                  "const": "image/jpeg"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "path": {
                  "const": "background.webp"
                },
                "mediaType": {
                  "const": "image/webp"
                }
              }
            }
          ]
        }
      ]
    },
    "previewAsset": {
      "allOf": [
        {
          "$ref": "#/$defs/assetCore"
        },
        {
          "type": "object",
          "properties": {
            "bytes": {
              "type": "integer",
              "maximum": 2097152
            },
            "width": {
              "type": "integer",
              "maximum": 2400
            },
            "height": {
              "type": "integer",
              "maximum": 2400
            }
          }
        },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "path": {
                  "const": "preview.png"
                },
                "mediaType": {
                  "const": "image/png"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "path": {
                  "enum": [
                    "preview.jpg",
                    "preview.jpeg"
                  ]
                },
                "mediaType": {
                  "const": "image/jpeg"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "path": {
                  "const": "preview.webp"
                },
                "mediaType": {
                  "const": "image/webp"
                }
              }
            }
          ]
        }
      ]
    }
  }
}
